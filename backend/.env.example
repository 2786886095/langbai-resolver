MEDIA_HARBOR_HOST=0.0.0.0
MEDIA_HARBOR_PORT=8787
MEDIA_HARBOR_DOWNLOAD_DIR=./downloads
MEDIA_HARBOR_CACHE_TTL_SECONDS=3600
MEDIA_HARBOR_JOB_TTL_SECONDS=21600
MEDIA_HARBOR_MAX_CONCURRENT_JOBS=2
MEDIA_HARBOR_CORS_ORIGINS=*
# Clash 等代理使用 198.18.0.0/15 Fake-IP DNS 时可开启；公网服务器请保持 false。
MEDIA_HARBOR_ALLOW_FAKE_IP_DNS=false
# MEDIA_HARBOR_FFMPEG_LOCATION=/usr/bin/ffmpeg

# 多源音乐搜索。Apple Music 曲库元数据、MusicBrainz、Audius、Internet Archive 和 Wikimedia Commons 无需密钥。
# Jamendo 需要在 developer.jamendo.com 创建应用；Audius Key 可提高请求额度。
# JAMENDO_CLIENT_ID=
# AUDIUS_API_KEY=

# 客户端自动更新清单；生产环境填写 GitHub Release 的固定下载地址。
LANGBAI_UPDATE_VERSION=1.0.7
LANGBAI_UPDATE_NOTES=B站扫码登录最高画质，iOS CA 证书修复，Android 固定发布签名
# LANGBAI_UPDATE_WINDOWS_URL=https://github.com/OWNER/langbai-resolver/releases/latest/download/langbai-resolver-Setup.exe
# LANGBAI_UPDATE_WINDOWS_SHA256=
