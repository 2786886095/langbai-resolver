# 默认仅建议监听本机。公开部署时必须同时配置实例令牌、精确 CORS、反向代理限流与 TLS。
MEDIA_HARBOR_HOST=127.0.0.1
MEDIA_HARBOR_PORT=8787
MEDIA_HARBOR_DOWNLOAD_DIR=./downloads

# Windows runner 会为每次启动生成随机令牌。自建公开服务请生成至少 32 字节随机值。
# MEDIA_HARBOR_INSTANCE_TOKEN=
# MEDIA_HARBOR_INSTANCE_ID=
MEDIA_HARBOR_CORS_ORIGINS=http://127.0.0.1:8787,http://localhost:8787

MEDIA_HARBOR_CACHE_TTL_SECONDS=3600
MEDIA_HARBOR_JOB_TTL_SECONDS=21600
MEDIA_HARBOR_JOB_TIMEOUT_SECONDS=3600
MEDIA_HARBOR_MAX_CONCURRENT_JOBS=2
MEDIA_HARBOR_MAX_PENDING_JOBS=32
MEDIA_HARBOR_MAX_DOWNLOAD_BYTES=8589934592
MEDIA_HARBOR_MAX_UPLOAD_BYTES=4294967296
MEDIA_HARBOR_MAX_TOTAL_STORAGE_BYTES=34359738368
MEDIA_HARBOR_MAX_HTML_BYTES=8388608
MEDIA_HARBOR_MAX_REDIRECTS=5

# Clash 等本地代理使用 198.18.0.0/15 Fake-IP DNS 时可开启；公网服务器保持 false。
MEDIA_HARBOR_ALLOW_FAKE_IP_DNS=false
# P2P 默认关闭。只有在隔离网络/容器并了解 tracker 与 peer 风险时才开启。
MEDIA_HARBOR_ALLOW_PEER_TO_PEER=false
# MEDIA_HARBOR_FFMPEG_LOCATION=/usr/bin

# Apple Music、MusicBrainz、Internet Archive、Wikimedia Commons 无需密钥。
# JAMENDO_CLIENT_ID=
# AUDIUS_API_KEY=

LANGBAI_UPDATE_VERSION=1.1.3
LANGBAI_UPDATE_NOTES=解析缓存与预热、自适应图片预览、全面媒体格式转换与安装包体积优化。
# LANGBAI_UPDATE_WINDOWS_URL=https://github.com/OWNER/langbai-resolver/releases/latest/download/langbai-resolver-Setup.exe
# LANGBAI_UPDATE_WINDOWS_SHA256=
# LANGBAI_UPDATE_WINDOWS_SIZE_BYTES=
# LANGBAI_UPDATE_WINDOWS_SIGNING_CERTIFICATE_SHA256=
# LANGBAI_UPDATE_ANDROID_URL=https://github.com/OWNER/langbai-resolver/releases/latest/download/langbai-resolver-Android.apk
# LANGBAI_UPDATE_IOS_URL=
# LANGBAI_UPDATE_WEB_URL=
