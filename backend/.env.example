# LANGBAI_UPDATE_IOS_URL=https://github.com/OWNER/langbai-resolver/releases/latest/download/langbai-resolver-iOS.ipa
# LANGBAI_UPDATE_WEB_URL=https://github.com/OWNER/langbai-resolver/releases/latest
